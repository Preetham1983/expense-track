{
    "version": 2,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "backend/app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/app.py/$1"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/$1",
            "check": true
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/.*",
            "dest": "frontend/index.html"
        }
    ]
}